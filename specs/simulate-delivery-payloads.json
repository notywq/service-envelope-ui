{
  "meta": {
    "title": "Simulate Delivery Button Payloads",
    "version": "1.0.0",
    "updatedAt": "2026-06-06",
    "endpointTemplate": "/api/delivery-status/{requestId}",
    "requestIdPlaceholder": "REQ-YYYYMMDD-XXX",
    "notes": [
      "Preferred fields: code_number or code_name.",
      "Legacy field 'status' is accepted by backend for backward compatibility, but avoid using it in new UI code.",
      "Guardrail: backend validates payload against selected delivery method and rejects cross-method codes."
    ]
  },
  "methods": {
    "email": {
      "flow": [
        "0 (email_pending)",
        "1 (email_sent)"
      ],
      "buttonPresets": [
        {
          "buttonKey": "EMAIL_PENDING",
          "label": "Email Pending",
          "code_number": 0,
          "code_name": "email_pending",
          "payload_code_number": {
            "code_number": 0,
            "notes": "Email queued for sending"
          },
          "payload_code_name": {
            "code_name": "email_pending",
            "notes": "Email queued for sending"
          }
        },
        {
          "buttonKey": "EMAIL_SENT",
          "label": "Email Sent",
          "code_number": 1,
          "code_name": "email_sent",
          "payload_code_number": {
            "code_number": 1,
            "notes": "Delivery email sent successfully"
          },
          "payload_code_name": {
            "code_name": "email_sent",
            "notes": "Delivery email sent successfully"
          }
        }
      ]
    },
    "physical_mail": {
