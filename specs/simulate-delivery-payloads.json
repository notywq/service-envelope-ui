  },
  "frontendIntegrationHints": {
    "route": "POST /api/delivery-status/{requestId}",
    "recommendedField": "code_number",
    "uiRule": "Render button set based on deliveryMethod returned by GET /api/delivery/{requestId}/method. Do not render buttons from other methods.",
    "apiGuardrailExpectedError": {
      "status": 400,
      "example": "Invalid code_number 3 for delivery method email"
    }
  }
}
