        {
          "buttonKey": "MAIL_DELIVERED",
          "label": "Delivered",
          "code_number": 3,
          "code_name": "delivered",
          "payload_code_number": {
            "code_number": 3,
            "trackingId": "TRACK-ABC-123",
            "location": "Recipient Address",
            "notes": "Package delivered and received"
          },
          "payload_code_name": {
            "code_name": "delivered",
            "trackingId": "TRACK-ABC-123",
            "location": "Recipient Address",
            "notes": "Package delivered and received"
          }
        }
      ]
    },
    "pickup": {
      "flow": [
        "0 (preparing)",
        "1 (ready_for_pickup)",
        "2 (picked_up)"
      ],
      "buttonPresets": [
